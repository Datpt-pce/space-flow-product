{
  "id": "image-batch-resize",
  "name": "Image Batch Resize",
  "version": "1.0.0",
  "category": "image",
  "inputs": [
    { "id": "files_in", "label": "Images", "type": "array", "required": true }
  ],
  "outputs": [
    { "id": "files_out", "label": "Images (resized)", "type": "array" }
  ],
  "config": [
    { "id": "output_format", "label": "Output Format",             "type": "select",  "options": ["png", "jpg"], "default": "png" },
    { "id": "manual_width",  "label": "Manual Width (px, 0=skip)", "type": "number",  "default": 0, "min": 0 },
    { "id": "manual_height", "label": "Manual Height (px, 0=skip)","type": "number",  "default": 0, "min": 0 },
    { "id": "base_px",       "label": "Smart Crop Base (px)",      "type": "number",  "default": 1080, "min": 64 },
    { "id": "ratio_1_1",     "label": "1:1",                       "type": "boolean", "default": false },
    { "id": "ratio_9_16",    "label": "9:16",                      "type": "boolean", "default": false },
    { "id": "ratio_16_9",    "label": "16:9",                      "type": "boolean", "default": false },
    { "id": "ratio_4_5",     "label": "4:5",                       "type": "boolean", "default": false },
    { "id": "ratio_3_4",     "label": "3:4",                       "type": "boolean", "default": false },
    { "id": "ratio_4_3",     "label": "4:3",                       "type": "boolean", "default": false },
    { "id": "ratio_2_3",     "label": "2:3",                       "type": "boolean", "default": false },
    { "id": "ratio_3_2",     "label": "3:2",                       "type": "boolean", "default": false }
  ],
  "executor": { "type": "python", "script": "executor.py" }
}
