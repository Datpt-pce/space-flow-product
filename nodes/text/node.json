{
  "id": "text",
  "name": "Text",
  "version": "1.0.0",
  "category": "data",
  "description": "A text block with configurable font size and bold style.",
  "icon": "type",
  "inputs": [
    { "id": "text_in", "label": "Text In", "type": "text", "required": false }
  ],
  "outputs": [
    { "id": "text", "label": "Text", "type": "text" }
  ],
  "config": [
    { "id": "content", "label": "Content", "type": "textarea", "default": "", "placeholder": "Type your text here..." },
    { "id": "fontSize", "label": "Font Size", "type": "number", "default": 14, "min": 8, "max": 72, "step": 1 },
    { "id": "bold", "label": "Bold", "type": "boolean", "default": false }
  ],
  "executor": "execute.js"
}
